<owl:AnnotationProperty rdf:about="http://swrl.stanford.edu/ontologies/3.3/swrla.owl#isRuleEnabled"/>

<owl:Class rdf:about="#Farm">
  <rdfs:subClassOf>
    <owl:Restriction>
      <owl:onProperty rdf:resource="#hasAnimalBreed"/>
      <owl:someValuesFrom rdf:resource="#Ruminant_Animal_Breed"/>
    </owl:Restriction>
  </rdfs:subClassOf>
  <rdfs:subClassOf>
    <owl:Restriction>
      <owl:onProperty rdf:resource="#hasAnimalCategory"/>
      <owl:someValuesFrom rdf:resource="#Ruminant_Animal_Category"/>
    </owl:Restriction>
  </rdfs:subClassOf>
  <rdfs:subClassOf>
    <owl:Restriction>
      <owl:onProperty rdf:resource="#hasAnimalEmissionFactor"/>
      <owl:someValuesFrom rdf:resource="#Ruminant_Animal_Emission_Factor"/>
    </owl:Restriction>
  </rdfs:subClassOf>
  <rdfs:subClassOf>
    <owl:Restriction>
      <owl:onProperty rdf:resource="#hasAnimalType"/>
      <owl:someValuesFrom rdf:resource="#Ruminant_Animal_Type"/>
    </owl:Restriction>
  </rdfs:subClassOf>
  <rdfs:subClassOf>
    <owl:Restriction>
      <owl:onProperty rdf:resource="#hasClimate"/>
      <owl:someValuesFrom rdf:resource="#Climate"/>
    </owl:Restriction>
  </rdfs:subClassOf>
  <rdfs:subClassOf>
    <owl:Restriction>
      <owl:onProperty rdf:resource="#hasEmitCH4"/>
      <owl:someValuesFrom rdf:resource="#Ruminant_Animal_Type"/>
    </owl:Restriction>
  </rdfs:subClassOf>
  <rdfs:subClassOf>
    <owl:Restriction>
      <owl:onProperty rdf:resource="#hasEmitCO2"/>
      <owl:someValuesFrom rdf:resource="#Electricity"/>
    </owl:Restriction>
  </rdfs:subClassOf>
  <rdfs:subClassOf>
    <owl:Restriction>
      <owl:onProperty rdf:resource="#hasEmitCO2"/>
      <owl:someValuesFrom rdf:resource="#Mobile_Machinery"/>
    </owl:Restriction>
  </rdfs:subClassOf>
  <rdfs:subClassOf>
    <owl:Restriction>
      <owl:onProperty rdf:resource="#hasEmitCO2"/>
      <owl:someValuesFrom rdf:resource="#Stationary_Machinery"/>
    </owl:Restriction>
  </rdfs:subClassOf>
  <rdfs:subClassOf>
    <owl:Restriction>
      <owl:onProperty rdf:resource="#hasGHGMeasureMethodAnimal"/>
      <owl:someValuesFrom rdf:resource="#GHG_Measure_Method_Animal"/>
    </owl:Restriction>
  </rdfs:subClassOf>
  <rdfs:subClassOf>
    <owl:Restriction>
      <owl:onProperty rdf:resource="#hasGHGMeasureMethodYear"/>
      <owl:someValuesFrom rdf:resource="#GHG_Measure_Method_Year"/>
    </owl:Restriction>
  </rdfs:subClassOf>
  <rdfs:subClassOf>
    <owl:Restriction>
      <owl:onProperty rdf:resource="#hasPart"/>
      <owl:someValuesFrom rdf:resource="#Farm_Area"/>
    </owl:Restriction>
  </rdfs:subClassOf>
  <rdfs:subClassOf>
    <owl:Restriction>
      <owl:onProperty rdf:resource="#isPartOf"/>
      <owl:someValuesFrom rdf:resource="#City"/>
    </owl:Restriction>
  </rdfs:subClassOf>
  <owl:disjointWith rdf:resource="#State"/>
</owl:Class>

<owl:Class rdf:about="#Ruminant_Animal_Breed">
  <rdfs:subClassOf rdf:resource="#Ruminant_Animal"/>
</owl:Class>

<owl:Class rdf:about="#Ruminant_Animal_Category">
  <rdfs:subClassOf rdf:resource="#Ruminant_Animal"/>
</owl:Class>

<owl:Class rdf:about="#Ruminant_Animal_Emission_Factor">
  <rdfs:subClassOf rdf:resource="#Ruminant_Animal"/>
</owl:Class>

<owl:Class rdf:about="#Ruminant_Animal_Type">
  <rdfs:subClassOf rdf:resource="#Ruminant_Animal"/>
  <rdfs:subClassOf>
    <owl:Restriction>
      <owl:onProperty rdf:resource="#hasDigestiveProcess"/>
      <owl:someValuesFrom rdf:resource="#Enteric_Fermentation"/>
    </owl:Restriction>
  </rdfs:subClassOf>
</owl:Class>

<owl:Class rdf:about="#Farm_Area">
  <rdfs:subClassOf>
    <owl:Restriction>
      <owl:onProperty rdf:resource="#hasClimate"/>
      <owl:someValuesFrom rdf:resource="#Climate"/>
    </owl:Restriction>
  </rdfs:subClassOf>
  <rdfs:subClassOf>
    <owl:Restriction>
      <owl:onProperty rdf:resource="#hasCoveragePeriod"/>
      <owl:someValuesFrom rdf:resource="#Coverage_Period"/>
    </owl:Restriction>
  </rdfs:subClassOf>
