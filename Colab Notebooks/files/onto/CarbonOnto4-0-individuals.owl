<?xml version="1.0"?>
<rdf:RDF xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
         xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
         xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
         xmlns:owl="http://www.w3.org/2002/07/owl#"
         xml:base="http://www.semanticweb.org/administrador/ontologies/2023/05/CarbonOnto4-0"
         xmlns="http://www.semanticweb.org/administrador/ontologies/2023/05/CarbonOnto4-0#"
         xmlns:swrl="http://www.w3.org/2003/11/swrl#"
         xmlns:swrl2="http://swrl.stanford.edu/ontologies/3.3/swrla.owl#">

<owl:Ontology rdf:about="http://www.semanticweb.org/administrador/ontologies/2023/05/CarbonOnto4-0">
  <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">An ontology to integrate data from heterogeneous sources for carbon footprint</rdfs:comment>
  <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Catte: emission factor (kg CH4/cabeça/ano). Ruminant_Animal_Emission_Factor values were entered in SWRL rules</rdfs:comment>
</owl:Ontology>

<owl:ObjectProperty rdf:about="#CH4IsEmittedBy">
  <rdfs:subPropertyOf rdf:resource="#Emit"/>
  <owl:inverseOf rdf:resource="#hasEmitCH4"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#Emit"/>

<owl:ObjectProperty rdf:about="#hasEmitCH4">
  <rdfs:subPropertyOf rdf:resource="#Emit"/>
  <rdfs:domain rdf:resource="#Farm"/>
  <rdfs:range rdf:resource="#CH4"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#CO2IsEmittedBy">
  <rdfs:subPropertyOf rdf:resource="#Emit"/>
  <owl:inverseOf rdf:resource="#hasEmitCO2"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#hasEmitCO2">
  <rdfs:subPropertyOf rdf:resource="#Emit"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#N2OIsEmittedBy">
  <rdfs:subPropertyOf rdf:resource="#Emit"/>
  <owl:inverseOf rdf:resource="#hasEmitN2O"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#hasEmitN2O">
  <rdfs:subPropertyOf rdf:resource="#Emit"/>
  <rdfs:domain rdf:resource="#Farm_Area"/>
  <rdfs:range rdf:resource="#N2O"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#hasAnimal"/>

